# Dashboard env vars — คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง (.env.local ถูก gitignore)

# --- Frontend (Vite, ต้องขึ้นต้น VITE_) ---
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Serverless function /api/ga (ตั้งค่าบน Vercel เท่านั้น ไม่ต้องขึ้นต้น VITE_) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
GA_PROPERTY_ID=123456789
GA_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
